# =============================================================
# .env — Homestay Microservices Platform
# Supabase (PostgreSQL) configuration
#
# HOW TO FILL THIS IN:
#   1. Go to your Supabase project → Settings → Database
#   2. Copy the "Connection string" (choose "Transaction pooler" for
#      production, or "Session mode" if you need persistent connections)
#   3. The format is:
#        postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[HOST]:[PORT]/postgres
#   4. In Supabase, all tables live in the same PostgreSQL database
#      (usually named "postgres"). Each service below uses the same host/port
#      but the DATABASE_URL can optionally specify a search_path (schema)
#      if you created separate schemas per service.
#
# IMPORTANT — Driver change:
#   Supabase is PostgreSQL, not MySQL. The docker-compose.yml must use
#   postgresql+psycopg2:// instead of mysql+pymysql://.
#   This file already uses the correct format; docker-compose.yml reads
#   these variables via the env_file directive (update it accordingly).
# =============================================================


# ─────────────────────────────────────────────────────────────
# SUPABASE — get these from:
#   Project → Settings → Database → Connection string
#   Project → Settings → API
# ─────────────────────────────────────────────────────────────

SUPABASE_PROJECT_REF=tqwoqxxpzfqdcnarmneh
SUPABASE_DB_HOST=aws-1-ap-south-1.pooler.supabase.com
SUPABASE_DB_PORT=6543
SUPABASE_DB_PORT_DIRECT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.tqwoqxxpzfqdcnarmneh
SUPABASE_DB_PASSWORD=esd123esd12

# Supabase REST/JS API (used if you ever add a frontend direct-query layer)
SUPABASE_URL=https://tqwoqxxpzfqdcnarmneh.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InRxd29xeHhwemZxZGNuYXJtbmVoIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ0OTI5MTksImV4cCI6MjA5MDA2ODkxOX0._UD5TDejKwmhwMDHPFikEMFABWE8jfZKPvHKFf-6a68
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InRxd29xeHhwemZxZGNuYXJtbmVoIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NDQ5MjkxOSwiZXhwIjoyMDkwMDY4OTE5fQ.dhKbbJHClW5dT_94sxi9_GjaGW-nPcNvzklmMSu1GSI


# ─────────────────────────────────────────────────────────────
# PER-SERVICE DATABASE URLs
# All point to the same Supabase PostgreSQL instance.
# Each service uses the same connection string since all tables
# are in the shared "postgres" database (public schema).
#
# Format:
#   postgresql+psycopg2://[USER]:[PASSWORD]@[HOST]:[PORT]/[DB]
#
# Use PORT 6543 (transaction pooler) for stateless services.
# Use PORT 5432 (direct) only for workers that hold long connections.
# ─────────────────────────────────────────────────────────────

BOOKING_DB_URL=postgresql+psycopg2://postgres.tqwoqxxpzfqdcnarmneh:esd123esd12@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
DEPOSIT_DB_URL=postgresql+psycopg2://postgres.tqwoqxxpzfqdcnarmneh:esd123esd12@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
USER_DB_URL=postgresql+psycopg2://postgres.tqwoqxxpzfqdcnarmneh:esd123esd12@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
LISTINGS_DB_URL=postgresql+psycopg2://postgres.tqwoqxxpzfqdcnarmneh:esd123esd12@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
AVAILABILITY_DB_URL=postgresql+psycopg2://postgres.tqwoqxxpzfqdcnarmneh:esd123esd12@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
STAY_DB_URL=postgresql+psycopg2://postgres.tqwoqxxpzfqdcnarmneh:esd123esd12@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
INSPECTION_DB_URL=postgresql+psycopg2://postgres.tqwoqxxpzfqdcnarmneh:esd123esd12@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
PAYMENT_LOGS_DB_URL=postgresql+psycopg2://postgres.tqwoqxxpzfqdcnarmneh:esd123esd12@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
SEARCH_DB_URL=postgresql+psycopg2://postgres.tqwoqxxpzfqdcnarmneh:esd123esd12@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
NOTIFICATION_DB_URL=postgresql+psycopg2://postgres.tqwoqxxpzfqdcnarmneh:esd123esd12@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

# Workers use direct connection (port 5432) — they run long-lived polling loops
BOOKING_EXPIRER_DB_URL=postgresql+psycopg2://postgres.tqwoqxxpzfqdcnarmneh:esd123esd12@aws-1-ap-south-1.pooler.supabase.com:5432/postgres
DEPOSIT_EXPIRER_DB_URL=postgresql+psycopg2://postgres.tqwoqxxpzfqdcnarmneh:esd123esd12@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# Workers also use transaction pooler (port 6543) — session pooler (5432) is not enabled
BOOKING_EXPIRER_DB_URL=postgresql+psycopg2://postgres%2Etqwoqxxpzfqdcnarmneh:esd123esd12@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
DEPOSIT_EXPIRER_DB_URL=postgresql+psycopg2://postgres%2Etqwoqxxpzfqdcnarmneh:esd123esd12@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require

